# Server
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL="postgresql://jerry:@localhost:5432/bikoba?schema=public"

# JWT — use long, random values in production (e.g. `openssl rand -base64 64`)
JWT_ACCESS_SECRET=bikoba
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=bikoba
JWT_REFRESH_TTL=7d

# bcrypt
BCRYPT_SALT_ROUNDS=12

# App
APP_URL=http://localhost:3000
EMAIL_VERIFICATION_TTL_HOURS=24
KYC_VERIFICATION_TTL_MONTHS=12
# Comma-separated days before expiry to send reminder emails (largest first).
KYC_REMINDER_OFFSET_DAYS=30,7,1

# Redis — used to cache product reads. If unreachable, the service no-ops.
REDIS_URL=redis://localhost:6379

# Meilisearch — leave MEILI_HOST blank to disable (falls back to Postgres ILIKE)
MEILI_HOST=http://localhost:7700
MEILI_MASTER_KEY=

# SMTP — leave SMTP_HOST blank in dev to fall back to console logging
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Bikoba <no-reply@bikoba.local>"

# Africa's Talking — leave AT_USERNAME blank to disable SMS (logs to console instead).
# When set, AT_API_KEY must also be set.
AT_USERNAME=sandbox
AT_API_KEY=
AT_SENDER_ID=
AT_ENVIRONMENT=sandbox

# OTP — used by phone verification + future MFA / password-reset flows.
OTP_TTL_MINUTES=5
OTP_MAX_ATTEMPTS=5
OTP_RATE_LIMIT_PER_HOUR=3

# Payment gateways — set the secret(s) of any provider you want to enable.
# Either provider can be left blank; PaymentsService returns 503 if a request
# targets an unconfigured provider.
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_WEBHOOK_SECRET=

# Where the PSP redirects the buyer after a checkout attempt. Typically your
# frontend's "payment result" page, which then calls GET /payments/verify.
PAYMENT_REDIRECT_URL=http://localhost:3000/payments/result

# Hours an order can sit in PENDING_PAYMENT before the daily sweep cancels it
# and restores its reserved stock. Set to 0 to disable the sweep.
ABANDONED_CART_GRACE_HOURS=24

# Cloudflare R2 — leave R2_ACCOUNT_ID blank to disable uploads entirely.
# When set, ALL R2_* vars must be set.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=bikoba-media
R2_PUBLIC_URL=https://cdn.bikoba.local
MAX_UPLOAD_BYTES=8388608

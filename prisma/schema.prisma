generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  BUYER
  SELLER
  ADMIN
}

enum SellerApplicationStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
  EXPIRED
}

enum OtpPurpose {
  PHONE_VERIFY
  LOGIN
  PASSWORD_RESET
  CHECKOUT_CONFIRM
}

enum OrderStatus {
  PENDING_PAYMENT
  CONFIRMED
  SHIPPED
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum PaymentProvider {
  PAYSTACK
  FLUTTERWAVE
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
  ABANDONED
}

enum PaymentChannel {
  CARD
  MOBILE_MONEY
  BANK_TRANSFER
  USSD
  OTHER
}

enum ReconcileEventKind {
  PHANTOM         // PSP reports a successful transaction we have no record of.
  MISMATCH        // PSP and our amount/currency disagree.
  RECONCILED      // Drift repaired: PSP says SUCCESS, we promoted PENDING/FAILED → SUCCESS.
  STUCK_RESOLVED  // Payment was already SUCCESS but Order was stuck in PENDING_PAYMENT.
}

model User {
  id              String    @id @default(uuid())
  email           String    @unique
  passwordHash    String
  role            Role      @default(BUYER)
  fullName        String?
  phoneNumber     String?   @unique
  phoneVerifiedAt DateTime?
  isActive        Boolean   @default(true)
  isEmailVerified Boolean   @default(false)
  emailVerifiedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  sessions             Session[]
  emailVerifications   EmailVerificationToken[]
  otpTokens            OtpToken[]
  stores               Store[]
  sellerApplication    SellerApplication?  @relation("UserSellerApplication")
  reviewedApplications SellerApplication[] @relation("AdminReviewedApplications")
  orders               Order[]             @relation("BuyerOrders")

  @@index([role])
  @@index([phoneNumber])
}

model OtpToken {
  id          String     @id @default(uuid())
  phoneNumber String
  userId      String?
  tokenHash   String
  purpose     OtpPurpose
  expiresAt   DateTime
  usedAt      DateTime?
  attempts    Int        @default(0)
  createdAt   DateTime   @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([phoneNumber, purpose])
  @@index([userId])
  @@index([expiresAt])
}

model SellerApplication {
  id String @id @default(uuid())

  userId String @unique

  fullName        String
  phone           String
  ghanaCardNumber String
  ghanaCardFront  String
  ghanaCardBack   String
  selfieUrl       String

  status          SellerApplicationStatus @default(PENDING)
  rejectionReason String?
  reviewedById    String?
  reviewedAt      DateTime?
  approvedAt      DateTime?
  expiresAt       DateTime?
  lastReminderAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User  @relation("UserSellerApplication", fields: [userId], references: [id], onDelete: Cascade)
  reviewer User? @relation("AdminReviewedApplications", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([reviewedById])
}

model Store {
  id          String  @id @default(uuid())
  name        String
  slug        String  @unique
  description String?
  logoUrl     String?
  bannerUrl   String?
  isActive    Boolean @default(true)
  currency    String  @default("USD")

  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  products Product[]
  orders   Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
  @@index([slug])
  @@index([isActive])
}

model EmailVerificationToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Category {
  id              String   @id @default(uuid())
  name            String
  slug            String   @unique
  description     String?
  imageUrl        String?
  icon            String?
  parentId        String?
  level           Int      @default(0)
  isFeatured      Boolean  @default(false)
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)
  metaTitle       String?
  metaDescription String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children Category[] @relation("CategoryHierarchy")
  products Product[]

  @@index([parentId])
  @@index([slug])
  @@index([isActive])
  @@index([isFeatured])
}

model Product {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  price       Decimal  @db.Decimal(12, 2)
  currency    String   @default("USD")
  sku         String?  @unique
  stock       Int      @default(0)
  images      String[] @default([])
  isActive    Boolean  @default(true)
  isFeatured  Boolean  @default(false)

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  storeId String
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  orderItems OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
  @@index([storeId])
  @@index([isActive])
  @@index([isFeatured])
}

model Session {
  id                String   @id @default(uuid())
  userId            String
  refreshTokenHash  String
  userAgent         String?
  ipAddress         String?
  deviceFingerprint String?
  expiresAt         DateTime
  revokedAt         DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([userId, deviceFingerprint])
}

model Order {
  id                 String      @id @default(uuid())
  buyerId            String
  storeId            String
  status             OrderStatus @default(PENDING_PAYMENT)
  totalAmount        Decimal     @db.Decimal(12, 2)
  currency           String
  shippingAddress    String
  notes              String?
  paidAt             DateTime?
  shippedAt          DateTime?
  outForDeliveryAt   DateTime?
  deliveredAt        DateTime?
  cancelledAt        DateTime?
  cancellationReason String?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  buyer    User        @relation("BuyerOrders", fields: [buyerId], references: [id], onDelete: Restrict)
  store    Store       @relation(fields: [storeId], references: [id], onDelete: Restrict)
  items    OrderItem[]
  payments Payment[]

  @@index([buyerId])
  @@index([storeId])
  @@index([status])
  @@index([createdAt])
}

model Payment {
  id             String          @id @default(uuid())
  orderId        String
  provider       PaymentProvider
  reference      String          @unique
  providerRef    String?
  amount         Decimal         @db.Decimal(12, 2)
  currency       String
  channel        PaymentChannel?
  status         PaymentStatus   @default(PENDING)
  initResponse   Json?
  verifyResponse Json?
  refundResponse Json?
  refundReason   String?
  initiatedAt    DateTime        @default(now())
  completedAt    DateTime?
  failedAt       DateTime?
  refundedAt     DateTime?

  order Order @relation(fields: [orderId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([status])
  @@index([provider])
  @@index([providerRef])
}

model OrderItem {
  id          String  @id @default(uuid())
  orderId     String
  productId   String
  productName String
  productSlug String
  unitPrice   Decimal @db.Decimal(12, 2)
  currency    String
  quantity    Int

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([productId])
}

model ReconcileRun {
  id                String   @id @default(uuid())
  startedAt         DateTime
  finishedAt        DateTime
  windowSince       DateTime
  windowUntil       DateTime
  scannedByProvider Json
  reconciledCount   Int      @default(0)
  stuckCount        Int      @default(0)
  phantomsCount     Int      @default(0)
  mismatchesCount   Int      @default(0)
  durationMs        Int
  createdAt         DateTime @default(now())

  events ReconcileEvent[]

  @@index([startedAt])
}

model ReconcileEvent {
  id        String             @id @default(uuid())
  runId     String
  kind      ReconcileEventKind
  provider  PaymentProvider?
  reference String?
  paymentId String?
  detail    Json?
  createdAt DateTime           @default(now())

  run ReconcileRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId, kind])
  @@index([kind, createdAt])
}
